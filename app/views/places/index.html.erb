<% content_for :title, "Places" %>

<div class="font-serif">
  <div class="w-full max-w-7xl mx-auto">

  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="text-center mb-2">
    <h1 class="text-4xl font-extrabold font-serif tracking-tight mb-1">Places</h1>
    <div class="uppercase tracking-widest text-xs text-gray-500 mb-4">Today's Highlights</div>
    <hr class="border-t border-gray-300 w-16 mx-auto mb-8">
  </div>

  <div class="flex justify-center mb-8">
    <%= link_to "New place", new_place_path, class: "rounded-md px-4 py-2 bg-blue-700 hover:bg-blue-600 text-white font-semibold shadow-sm transition" %>
  </div>

  <div id="places" class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
    <% if @places.any? %>
      <% @places.each do |place| %>
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 flex flex-col justify-between min-h-[180px] hover:shadow-md transition">
          <h2 class="text-2xl font-bold font-serif mb-1 text-gray-900"><%= place.name %></h2>
          <div class="text-xs text-gray-500 mb-2 uppercase tracking-wider"><%= place.location %></div>
          <% if place.description.present? %>
            <p class="text-gray-700 text-justify mb-3 line-clamp-4"><%= truncate(strip_tags(place.description), length: 180) %></p>
          <% end %>
          <div class="flex flex-wrap gap-2 mt-auto pt-2">
            <%= link_to "Show", place, class: "rounded-md px-3.5 py-2 bg-gray-100 hover:bg-gray-50 text-sm font-medium" %>
            <%= link_to "Edit", edit_place_path(place), class: "rounded-md px-3.5 py-2 bg-gray-100 hover:bg-gray-50 text-sm font-medium" %>
            <%= button_to "Destroy", place, method: :delete, class: "rounded-md px-3.5 py-2 text-white bg-red-600 hover:bg-red-500 text-sm font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10 text-lg italic">No places found.</p>
    <% end %>
  </div>
</div>
