<% content_for :title, "Showing place" %>

<%# update the location stream %>
<%= turbo_stream_from @place %>

<div class=" w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>
  <%= link_to "Back to places", places_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>

  <h1 class="font-bold text-4xl"><%= @place.name %></h1>
  <p class="text-gray-500 mb-4"><%= @place.location %></p>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-6">
    <!-- Map Column -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <%= render "map", place: @place %>
    </div>
    
    <!-- About This Place Column -->
    <div class="bg-white rounded-lg shadow p-6" id="place-info">
      <h2 class="text-2xl font-bold mb-4">About This Place</h2>
      <div class="space-y-4" id="place-description">
        <%# This div will be filled with content from the controller %>
        <% if @place_info.present? %>
          <div class="prose max-w-none">
            <%= @place_info.html_safe %>
          </div>
        <% else %>
          <p class="italic text-gray-500">Loading information about <%= @place.name %>...</p>
          <div class="w-full flex justify-center">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-500"></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="my-6 bg-white rounded-lg shadow p-6" id="nearby-places">
    <h2 class="text-2xl font-bold mb-4">Nearby Places</h2>
    <div class="space-y-2" id="nearby-places-list">
      <%# This div will be filled with content from the controller %>
      <% if @nearby_places.present? && @nearby_places.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% @nearby_places.each do |place| %>
            <div class="p-4 border rounded-lg hover:bg-gray-50 transition">
              <h3 class="font-semibold"><%= place[:name] %></h3>
              <p class="text-sm text-gray-600"><%= place[:address] %></p>
              <% if place[:rating].present? %>
                <div class="flex items-center mt-1">
                  <span class="text-yellow-400">★</span>
                  <span class="text-sm ml-1"><%= place[:rating] %></span>
                  <span class="text-xs text-gray-500 ml-2">(<%= place[:reviews] %> reviews)</span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="italic text-gray-500">Loading nearby places...</p>
        <div class="w-full flex justify-center">
          <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-500"></div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-6 space-x-2">
    <%= link_to "Edit this place", edit_place_path(@place), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
    <%= button_to "Destroy this place", @place, method: :delete, form_class: "sm:inline-block mt-2 sm:mt-0 sm:ml-2", class: "w-full rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
