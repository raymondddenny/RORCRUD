<div id="<%= dom_id place %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= place.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Location:</strong>
    <%= place.location %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Latitude:</strong>
    <%= place.latitude %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Longitude:</strong>
    <%= place.longitude %>
  </div>
</div>
